{
  "name": "kubelb-dashboard-api",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc && mkdir -p dist/hubble && cp -R src/hubble/proto dist/hubble/proto",
    "license:check": "bash ../hack/check-licenses.sh",
    "start": "node dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/http-proxy": "^11.5.0",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@kubernetes/client-node": "^1.4.0",
    "fastify": "^5.9.0",
    "jose": "^6.2.3",
    "openid-client": "^6.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
