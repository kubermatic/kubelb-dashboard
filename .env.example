# Frontend
VITE_API_URL=

# API Server (set all 4 OIDC vars or none)
# OIDC_ISSUER=https://dex.example.com
# OIDC_CLIENT_ID=kubelb-dashboard
# OIDC_CLIENT_SECRET=
# SESSION_SECRET=
# OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
# OIDC_SCOPES=openid email profile groups offline_access
# SESSION_MAX_AGE=86400
# Enable watch streaming for resource lists (defaults to polling every 15s)
# WATCH_ENABLED=false
# Prometheus URL for per-proxy metrics (empty = auto-discover or disabled)
# PROMETHEUS_URL=http://prometheus.monitoring.svc:9090
# Auto-discover Prometheus when PROMETHEUS_URL is empty (default true)
# PROMETHEUS_AUTODISCOVER=true
# Hubble Relay address for the live Traffic view (empty = auto-discover or disabled)
# HUBBLE_RELAY_ADDRESS=hubble-relay.kube-system.svc:80
# Auto-discover Hubble Relay when HUBBLE_RELAY_ADDRESS is empty (default true)
# HUBBLE_AUTODISCOVER=true
